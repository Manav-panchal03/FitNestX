<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/app_theme"
            android:layout_marginBottom="16dp"/>

        <!-- CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="#EEEEEE"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- NAME -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Name">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- BIO -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Bio">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEditBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minLines="2"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- GOAL WEIGHT -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Goal Weight (kg)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etGoalWeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- GOAL TYPE LABEL -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Goal Type"
                    android:textStyle="bold"
                    android:textColor="@color/app_theme"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"/>

                <!-- GOAL TYPE -->
                <Spinner
                    android:id="@+id/spGoalType"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_spinner_fitnestx"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CHANGE PASSWORD -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnChangePassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Change Password"
            android:textAllCaps="false"
            android:layout_marginTop="16dp"
            app:backgroundTint="#FFF3E0"
            android:textColor="@color/app_theme"
            app:cornerRadius="14dp"/>

        <!-- PASSWORD SECTION (HIDDEN INITIALLY) -->
        <LinearLayout
            android:id="@+id/layoutPasswordSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="12dp">

            <EditText
                android:id="@+id/etOldPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Current Password"
                android:inputType="textPassword"/>

            <EditText
                android:id="@+id/etNewPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:hint="New Password"
                android:inputType="textPassword"/>

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:hint="Confirm Password"
                android:inputType="textPassword"/>

        </LinearLayout>

        <!-- SAVE -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Changes"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            app:backgroundTint="@color/app_theme2"
            app:cornerRadius="16dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>