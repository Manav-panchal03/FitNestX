<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main2"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_margin="20dp"
    tools:context=".HabitStatsActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Habits Insights"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/app_theme" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Number of habits completed per day"
        android:textSize="14sp"
        android:textColor="#7B6F72"
        android:layout_marginBottom="30dp"/>

    <com.github.mikephil.charting.charts.BarChart
        android:id="@+id/habitBarChart"
        android:layout_width="match_parent"
        android:layout_marginTop="111dp"
        android:layout_height="400dp" />

    <TextView
        android:id="@+id/tvTotalCompleted"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Loading stats..."
        android:gravity="center"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#92A3FD"/>

</LinearLayout>